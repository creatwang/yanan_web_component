{
  "name": "yn-web-component",
  "version": "1.0.2",
  "description": "Floema-style Lit Web Components for DTC and cross-border e-commerce storefronts — navigation, SKU selector, checkout address, drawer, toast. Tree-shaking subpath exports.",
  "homepage": "https://web-components.yanan.store/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creatwang/yanan_web_component.git"
  },
  "bugs": {
    "url": "https://github.com/creatwang/yanan_web_component/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "unpkg": "./dist/index.iife.js",
  "jsdelivr": "./dist/index.iife.js",
  "types": "./dist/types/index.d.ts",
  "customElements": "custom-elements.json",
  "web-types": "./web-types.json",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./define": {
      "types": "./dist/types/define.d.ts",
      "import": "./dist/define.js",
      "require": "./dist/define.cjs"
    },
    "./theme.css": "./src/styles/theme.css",
    "./asset/svg": {
      "types": "./dist/types/asset/svg/index.d.ts",
      "import": "./dist/asset/svg.js",
      "require": "./dist/asset/svg.cjs"
    },
    "./components/yn-button": {
      "types": "./dist/types/components/yn-button/yn-button.d.ts",
      "import": "./dist/components/yn-button.js",
      "require": "./dist/components/yn-button.cjs"
    },
    "./components/yn-input": {
      "types": "./dist/types/components/yn-input/yn-input.d.ts",
      "import": "./dist/components/yn-input.js",
      "require": "./dist/components/yn-input.cjs"
    },
    "./components/yn-navigation": {
      "types": "./dist/types/components/yn-navigation/yn-navigation.d.ts",
      "import": "./dist/components/yn-navigation.js",
      "require": "./dist/components/yn-navigation.cjs"
    },
    "./components/yn-search": {
      "types": "./dist/types/components/yn-search/yn-search.d.ts",
      "import": "./dist/components/yn-search.js",
      "require": "./dist/components/yn-search.cjs"
    },
    "./components/yn-group-pick": {
      "types": "./dist/types/components/yn-group-pick/yn-group-pick.d.ts",
      "import": "./dist/components/yn-group-pick.js",
      "require": "./dist/components/yn-group-pick.cjs"
    },
    "./components/yn-pick": {
      "types": "./dist/types/components/yn-pick/yn-pick.d.ts",
      "import": "./dist/components/yn-pick.js",
      "require": "./dist/components/yn-pick.cjs"
    },
    "./components/yn-dropdown": {
      "types": "./dist/types/components/yn-dropdown/yn-dropdown.d.ts",
      "import": "./dist/components/yn-dropdown.js",
      "require": "./dist/components/yn-dropdown.cjs"
    },
    "./components/yn-dropdown-pick": {
      "types": "./dist/types/components/yn-dropdown-pick/yn-dropdown-pick.d.ts",
      "import": "./dist/components/yn-dropdown-pick.js",
      "require": "./dist/components/yn-dropdown-pick.cjs"
    },
    "./components/yn-drawer": {
      "types": "./dist/types/components/yn-drawer/yn-drawer.d.ts",
      "import": "./dist/components/yn-drawer.js",
      "require": "./dist/components/yn-drawer.cjs"
    },
    "./components/yn-toast": {
      "types": "./dist/types/components/yn-toast/yn-toast.d.ts",
      "import": "./dist/components/yn-toast.js",
      "require": "./dist/components/yn-toast.cjs"
    },
    "./components/yn-icon-connect-button": {
      "types": "./dist/types/components/yn-icon-connect-button.d.ts",
      "import": "./dist/components/yn-icon-connect-button.js",
      "require": "./dist/components/yn-icon-connect-button.cjs"
    },
    "./components/yn-pull-cord-switch": {
      "types": "./dist/types/components/yn-pull-cord-switch/yn-pull-cord-switch.d.ts",
      "import": "./dist/components/yn-pull-cord-switch.js",
      "require": "./dist/components/yn-pull-cord-switch.cjs"
    },
    "./components/yn-quantity": {
      "types": "./dist/types/components/yn-quantity/yn-quantity.d.ts",
      "import": "./dist/components/yn-quantity.js",
      "require": "./dist/components/yn-quantity.cjs"
    },
    "./components/yn-checkout-address": {
      "types": "./dist/types/components/yn-checkout-address/yn-checkout-address.d.ts",
      "import": "./dist/components/yn-checkout-address.js",
      "require": "./dist/components/yn-checkout-address.cjs"
    },
    "./components/yn-sku-selector": {
      "types": "./dist/types/components/yn-sku-selector/yn-sku-selector.d.ts",
      "import": "./dist/components/yn-sku-selector.js",
      "require": "./dist/components/yn-sku-selector.cjs"
    },
    "./umd": {
      "default": "./dist/index.umd.js"
    },
    "./iife": {
      "default": "./dist/index.iife.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md"
  ],
  "scripts": {
    "dev": "vite --open /",
    "dev:docs": "vite --open /",
    "dev:pull-cord": "vite --open /demos/pull-cord-switch-demo.html",
    "dev:menu-mobile-bg": "vite --open /demos/menu-mobile-bg-demo.html",
    "dev:unified-address": "vite --open /demos/address/unified-address-demo.html",
    "dev:google-address": "vite --open /demos/address/google-address-demo.html",
    "dev:dr5hn-region": "vite --open /demos/address/dr5hn-region-demo.html",
    "build:docs": "pnpm run generate:sitemap && vite build",
    "build": "vite build && vite build --config vite.config.umd-iife.ts && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "analyze": "cem analyze && node scripts/generate-ide-metadata.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "web-test-runner --config web-test-runner.config.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "publish:npm": "pnpm build && pnpm publish --access public --no-git-checks"
  },
  "keywords": [
    "web-components",
    "web components",
    "custom-elements",
    "lit",
    "lit-element",
    "component-library",
    "ui-components",
    "ecommerce",
    "e-commerce",
    "dtc",
    "storefront",
    "cross-border",
    "checkout",
    "sku",
    "floema",
    "shadow-dom",
    "tree-shaking"
  ],
  "author": "creatwang",
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@countrystatecity/countries-browser": "^1.0.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/test": "8.6.14",
    "@storybook/web-components": "8.6.14",
    "@storybook/web-components-vite": "^8.6.14",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "autoprefixer": "^10.4.21",
    "custom-element-jet-brains-integration": "^1.7.0",
    "custom-element-vs-code-integration": "^1.5.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.1",
    "vitest": "^4.1.5"
  }
}
