{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types"
  },
  "include": ["src"],
  "exclude": ["src/**/*.stories.ts", "src/**/*.spec.ts", "src/dev.ts", "src/test-setup.ts"]
}
